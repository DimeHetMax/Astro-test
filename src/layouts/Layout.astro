---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>

</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  html {
    margin: 0;
    width: 100%;
    min-height: 100%;
    scroll-behavior: smooth;
    color-scheme: light;
    font-family:
      -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text",
      "Helvetica Neue", Arial, sans-serif;
    background: #f5f5f7;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100vh;
    color: #1d1d1f;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(245, 245, 247, 0.96) 45%, #f5f5f7 100%);
    text-rendering: geometricPrecision;
    -webkit-font-smoothing: antialiased;
  }

  :global(a) {
    color: inherit;
  }

  :global(h1),
  :global(p) {
    margin-top: 0;
  }

  :global(body > h1),
  :global(body > p),
  :global(main:not(.welcome__main)) {
    max-width: 980px;
    margin-inline: auto;
    padding-inline: 24px;
  }
  :global(ul) {
    list-style: none;
  }

  :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    body {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(245, 245, 247, 0.98) 52%, #f5f5f7 100%);
    }
  }
</style>
