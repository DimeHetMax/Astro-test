---
import background from "../assets/background.svg";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main class="welcome__main">
    <section class="hero" aria-labelledby="hero-title">
      <p class="eyebrow">Full stack Astro blog</p>
      <h1 id="hero-title">Create crisp stories with a fast, modern publishing experience.</h1>
      <p class="lede">
        A refined starter interface with quiet depth, glassy surfaces, and
        focused typography inspired by Apple product pages.
      </p>

      <div class="hero-actions" aria-label="Primary actions">
        <a class="primary-action" href="/blog/blog">Read the blog</a>
        <a class="secondary-action" href="/about">Learn more</a>
      </div>
    </section>

    <section class="feature-grid" aria-label="Site highlights">
      <article>
        <span>01</span>
        <h2>Fluid layout</h2>
        <p>Generous spacing, balanced type, and responsive sections keep every page calm and readable.</p>
      </article>
      <article>
        <span>02</span>
        <h2>Soft surfaces</h2>
        <p>Subtle translucent panels and hairline borders create depth without visual noise.</p>
      </article>
      <article>
        <span>03</span>
        <h2>Fast foundation</h2>
        <p>Astro keeps the experience light while the interface feels polished from the first viewport.</p>
      </article>
    </section>
  </main>
</div>

<style>
  #background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.18;
    filter: blur(90px) saturate(110%);
    transform: scale(1.08);
  }

  #container {
    min-height: calc(100vh - 72px);
    overflow: hidden;
  }

  main {
    width: min(1120px, calc(100% - 48px));
    min-height: calc(100vh - 96px);
    margin: 0 auto;
    padding: 84px 0 54px;
    display: grid;
    align-content: center;
    gap: 34px;
  }

  .hero {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #0066cc;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0;
  }

  h1 {
    max-width: 940px;
    margin: 0;
    color: #1d1d1f;
    font-size: clamp(48px, 7vw, 86px);
    line-height: 0.98;
    font-weight: 800;
    letter-spacing: 0;
  }

  .lede {
    max-width: 690px;
    margin: 24px auto 0;
    color: #6e6e73;
    font-size: clamp(19px, 2vw, 25px);
    line-height: 1.36;
    font-weight: 500;
    letter-spacing: 0;
  }

  .hero-actions {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .primary-action,
  .secondary-action {
    min-height: 46px;
    padding: 13px 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  .primary-action {
    color: white;
    background: #0071e3;
    box-shadow: 0 14px 30px rgba(0, 113, 227, 0.24);
  }

  .secondary-action {
    color: #0066cc;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(0, 102, 204, 0.14);
  }

  .primary-action:hover,
  .secondary-action:hover,
  .primary-action:focus-visible,
  .secondary-action:focus-visible {
    transform: translateY(-2px);
    outline: none;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  article {
    min-height: 220px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid rgba(29, 29, 31, 0.08);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.07);
    backdrop-filter: blur(24px) saturate(165%);
  }

  article span {
    margin-bottom: auto;
    color: #86868b;
    font-size: 13px;
    font-weight: 700;
  }

  article h2 {
    margin: 0 0 10px;
    color: #1d1d1f;
    font-size: 22px;
    line-height: 1.12;
    letter-spacing: 0;
  }

  article p {
    margin: 0;
    color: #6e6e73;
    font-size: 15px;
    line-height: 1.5;
  }

  @media screen and (max-width: 768px) {
    main {
      width: min(100% - 32px, 1120px);
      padding-top: 56px;
    }

    h1 {
      font-size: clamp(42px, 13vw, 62px);
      line-height: 1.02;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    article {
      min-height: 170px;
    }
  }

  @media screen and (max-width: 480px) {
    .hero-actions {
      width: 100%;
    }

    .primary-action,
    .secondary-action {
      width: 100%;
    }
  }
</style>
